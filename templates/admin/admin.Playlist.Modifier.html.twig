{% extends "baseadmin.html.twig" %}

{% block page_title %}
    Gestion des playlists
{% endblock %}

{% block body %}
    <h2>Détail Playlist :</h2>
    <div class="row mt-3">
        <div class="col">
           {{ include('_admin.Playlist.form.html.twig') }}
        </div>
    <div class="col">
            <!-- boucle sur l'affichage des formations -->
            {% for formation in playlistformations %}
                <div class="row mt-1">
                    <div class="col-md-auto">
                        {% if formation.videoName %}
                            <a href="{{ path('formations.showone', {id: formation.id}) }}">
                                <video width="200" muted style="border-radius:6px; cursor:pointer;">
                                    <source src="{{ asset('video/formation/' ~ formation.videoName) }}" type="video/mp4"> 
                                </video> 
                            </a>
                                <!-- affichage youtube -->
                        {% elseif formation.miniature %}
                            <a href="{{ path('formations.showone', {id:formation.id}) }}">
                                <img src="{{ formation.miniature }}" alt="formations.showone">
                            </a>
                        {% endif %}  
                    </div>
                    <div class="col d-flex align-items-center">
                        <a href="{{ path('formations.showone', {id:formation.id}) }}" 
                           class="link-secondary text-decoration-none">
                            {{ formation.title }}
                        </a>          
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
