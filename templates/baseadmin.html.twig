{% extends "base.html.twig" %}

{% block title %}{% endblock %}
{% block stylesheets %}{% endblock %}

{% block top %}
    <!-- entête -->
  <div class="container text-end">
    {% if app.user %}
        <a href="{{ path('logout') }}">se déconnecter</a>
    {% endif %}
  </div>
    <div class="container">
        <!-- titre -->
        <div class="text-center">
            <h1>{% block page_title %}Gestion des formations{% endblock %}</h1>
        </div>
         <!-- menu -->
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav mr-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('admin.formations') }}">Formations</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{path('admin.playlists')  }}">Playlists</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('admin.categories') }}">Catégories</a>
                    </li>           
                </ul>
            </div>
        </nav> 
    </div>
{% endblock %}

{% block body %}{% endblock %}
{% block javascripts %}{% endblock %}